---
import "../styles/global.css";

type Props = {
  title: string;
  description?: string;
  canonicalPath?: string;
};

const {
  title,
  description = "CalcHub — fast, modern utility calculators.",
  canonicalPath = Astro.url.pathname,
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, Astro.site ?? Astro.url.origin).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Syne:wght@600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />

    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Google Analytics (placeholder) -->
    <!--
      Paste GA code here.
    -->
  </head>
  <body class="min-h-dvh bg-bg text-text">
    <header class="bg-navy text-white">
      <div class="container-page">
        <div class="flex items-center justify-between py-4">
          <a href="/" class="flex items-center gap-2">
            <span class="font-heading text-lg tracking-tight">CalcHub</span>
            <span class="rounded-full bg-white/10 px-2 py-0.5 text-xs text-white/80">Utilities</span>
          </a>
          <nav class="hidden sm:flex items-center gap-6 text-sm text-white/80">
            <a class="hover:text-white" href="/">Home</a>
            <a class="hover:text-white" href="/vat-calculator">VAT</a>
            <a class="hover:text-white" href="/age-calculator">Age</a>
            <a class="hover:text-white" href="/mortgage-calculator">Mortgage</a>
          </nav>
        </div>
      </div>
    </header>

    <main class="container-page py-10">
      <slot />
    </main>

    <footer class="border-t border-border bg-bg">
      <div class="container-page">
        <div class="grid grid-cols-1 gap-8 py-10 sm:grid-cols-3">
          <div>
            <a href="/" class="inline-flex items-center gap-2">
              <span class="font-heading text-lg tracking-tight text-text">CalcHub</span>
            </a>
            <p class="mt-3 text-sm leading-relaxed text-muted">Free calculators for everyday life</p>
          </div>

          <div class="sm:justify-self-center">
            <h2 class="text-sm font-semibold text-text">Top calculators</h2>
            <div class="mt-3 grid grid-cols-1 gap-2 text-sm text-muted">
              <a class="hover:text-text" href="/age-calculator">Age Calculator</a>
              <a class="hover:text-text" href="/mortgage-calculator">Mortgage Calculator</a>
              <a class="hover:text-text" href="/vat-calculator">VAT Calculator</a>
              <a class="hover:text-text" href="/tip-calculator">Tip Calculator</a>
              <a class="hover:text-text" href="/percentage-calculator">Percentage Calculator</a>
            </div>
          </div>

          <div class="sm:justify-self-end">
            <h2 class="text-sm font-semibold text-text">Company</h2>
            <div class="mt-3 flex flex-col gap-2 text-sm text-muted">
              <a class="hover:text-text" href="/about">About</a>
              <a class="hover:text-text" href="/contact">Contact</a>
              <a class="hover:text-text" href="/privacy-policy">Privacy Policy</a>
            </div>
          </div>
        </div>

        <div class="border-t border-border py-6">
          <p class="text-sm text-muted">{new Date().getFullYear()} CalcHub. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
