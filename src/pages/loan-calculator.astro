---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Loan Calculator — Monthly EMI and Total Interest | CalcHub"
  description="Free loan calculator. Calculate monthly EMI, total interest and full repayment cost for personal, car or student loans."
>
  <div class="mx-auto w-full max-w-4xl">
    <nav class="text-sm text-muted" aria-label="Breadcrumb">
      <a class="hover:text-text" href="/">Home</a>
      <span class="px-2" aria-hidden="true">›</span>
      <span class="text-text">Loan Calculator</span>
    </nav>

    <div class="mt-6">
      <p class="text-sm font-medium text-muted">Calculator</p>
      <h1 class="mt-3 font-heading text-3xl tracking-tight sm:text-4xl">Loan Calculator</h1>
      <p class="mt-4 text-base leading-relaxed text-muted">
        Calculate your monthly EMI, total interest, and total repayment cost for common loan types.
      </p>
    </div>

    <section class="mt-8 rounded-xl border border-border bg-card p-6 shadow-soft sm:p-8" aria-label="Loan calculator">
      <form id="loan-form" class="grid grid-cols-1 gap-4 sm:grid-cols-2" autocomplete="off">
        <div>
          <label class="block text-sm font-medium text-text" for="amount">Loan amount ($)</label>
          <input
            id="amount"
            name="amount"
            inputmode="decimal"
            placeholder="e.g. 20000"
            class="mt-2 w-full rounded-lg border border-border bg-white px-3 py-2 text-text shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
            required
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-text" for="rate">Annual interest rate (%)</label>
          <input
            id="rate"
            name="rate"
            inputmode="decimal"
            placeholder="e.g. 11.5"
            class="mt-2 w-full rounded-lg border border-border bg-white px-3 py-2 text-text shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
            required
          />
        </div>

        <div>
          <div class="flex items-end justify-between gap-3">
            <label class="block text-sm font-medium text-text" for="term">Loan term</label>
            <div class="inline-flex items-center rounded-lg border border-border bg-bg p-1">
              <label class="inline-flex items-center gap-2 rounded-md px-3 py-2 text-sm text-muted">
                <input type="radio" name="termUnit" value="months" checked />
                Months
              </label>
              <label class="inline-flex items-center gap-2 rounded-md px-3 py-2 text-sm text-muted">
                <input type="radio" name="termUnit" value="years" />
                Years
              </label>
            </div>
          </div>
          <input
            id="term"
            name="term"
            inputmode="numeric"
            placeholder="e.g. 36"
            class="mt-2 w-full rounded-lg border border-border bg-white px-3 py-2 text-text shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
            required
          />
          <p id="termHint" class="mt-2 text-xs text-muted">Enter the term in months.</p>
        </div>

        <div>
          <label class="block text-sm font-medium text-text" for="type">Loan type</label>
          <select
            id="type"
            name="type"
            class="mt-2 w-full rounded-lg border border-border bg-white px-3 py-2 text-text shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
          >
            <option value="personal" selected>Personal Loan</option>
            <option value="auto">Car and Auto Loan</option>
            <option value="student">Student Loan</option>
            <option value="business">Business Loan</option>
          </select>
        </div>

        <div class="sm:col-span-2">
          <button
            type="submit"
            class="inline-flex w-full items-center justify-center rounded-lg bg-accent px-4 py-2 text-sm font-semibold text-white shadow-sm hover:opacity-95 focus:outline-none focus:ring-2 focus:ring-accent/30 sm:w-auto"
          >
            Calculate EMI
          </button>
          <p id="error" class="mt-3 hidden text-sm font-medium text-accent"></p>
        </div>
      </form>

      <div class="mt-8 rounded-xl border border-border bg-bg p-5" aria-label="EMI result">
        <div class="text-xs font-semibold uppercase tracking-wide text-muted">Monthly EMI</div>
        <div id="emi" class="mt-2 font-heading text-3xl text-text sm:text-4xl">—</div>
        <div id="emiNote" class="mt-2 text-sm text-muted">Estimated principal + interest payment.</div>
      </div>

      <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3" aria-label="Loan totals">
        <div class="rounded-xl border border-border bg-card p-5">
          <div class="text-xs font-medium uppercase tracking-wide text-muted">Total interest payable</div>
          <div id="totalInterest" class="mt-2 font-heading text-2xl text-text">—</div>
        </div>
        <div class="rounded-xl border border-border bg-card p-5">
          <div class="text-xs font-medium uppercase tracking-wide text-muted">Total amount payable</div>
          <div id="totalPayable" class="mt-2 font-heading text-2xl text-text">—</div>
        </div>
        <div class="rounded-xl border border-border bg-card p-5">
          <div class="text-xs font-medium uppercase tracking-wide text-muted">Split (principal vs interest)</div>
          <div class="mt-3">
            <div class="flex items-center justify-between text-xs font-semibold text-muted">
              <span id="pPct">—</span>
              <span id="iPct">—</span>
            </div>
            <div class="mt-2 h-3 overflow-hidden rounded-full bg-bg ring-1 ring-border">
              <div id="pBar" class="h-3 bg-navy" style="width: 0%"></div>
              <div id="iBar" class="-mt-3 h-3 bg-accent" style="width: 0%"></div>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-6 flex flex-wrap items-center justify-between gap-3 rounded-xl border border-border bg-card px-5 py-4">
        <p class="text-sm text-muted">Payoff schedule</p>
        <fieldset class="flex flex-wrap items-center gap-4 border-0 p-0 text-sm">
          <legend class="sr-only">Table granularity</legend>
          <span class="font-medium text-text">View</span>
          <label class="inline-flex cursor-pointer items-center gap-2 text-muted">
            <input type="radio" name="loanGranularity" value="year" checked class="accent-accent" />
            By year
          </label>
          <label class="inline-flex cursor-pointer items-center gap-2 text-muted">
            <input type="radio" name="loanGranularity" value="month" class="accent-accent" />
            By month
          </label>
        </fieldset>
      </div>

      <div class="mt-4 overflow-hidden rounded-xl border border-border" aria-label="Payoff summary">
        <div class="bg-card px-5 py-4">
          <h2 class="font-heading text-lg text-text">Payoff summary</h2>
          <p class="mt-1 text-sm text-muted">Interest, principal, and remaining balance by year or by month.</p>
        </div>
        <div class="max-h-[min(28rem,70vh)] overflow-x-auto overflow-y-auto bg-white">
          <table class="min-w-full border-collapse">
            <thead class="sticky top-0 z-10 bg-bg shadow-sm">
              <tr class="border-t border-border">
                <th id="loanPeriodHead" class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Year</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Payments</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Interest paid</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Principal paid</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Remaining balance</th>
              </tr>
            </thead>
            <tbody id="yearBody">
              <tr class="border-t border-border">
                <td class="px-5 py-4 text-sm text-muted" colspan="5">Calculate to see the schedule.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="mt-12" aria-label="Loan calculator guide">
      <article class="prose max-w-none">
        <h1 class="font-heading text-2xl text-text">Loan Calculator</h1>
        <p class="mt-4 text-base leading-relaxed text-muted">
          Whether you’re planning a personal loan, financing a car, paying for education, or investing in a business, the most practical question is the same:
          how much will you pay each month, and how much interest will the loan cost over its lifetime? A loan calculator helps you answer those questions in
          seconds by estimating your monthly EMI (Equated Monthly Installment), the total interest payable, and the total repayment amount. It’s a simple way to
          compare scenarios—such as a shorter term with higher payments versus a longer term with lower payments—and to understand how the interest rate influences
          your overall cost.
        </p>
        <p class="mt-4 text-base leading-relaxed text-muted">
          This calculator uses the standard EMI formula for amortizing loans with fixed monthly payments. That means each payment includes both interest and
          principal. Early in the schedule, interest makes up a larger portion of the EMI because the outstanding balance is higher. Over time, as the balance
          decreases, the interest portion falls and more of the EMI goes toward paying down principal. That’s why a lower interest rate or a shorter term can
          dramatically reduce the total interest, even if the EMI changes only moderately.
        </p>

        <h2 class="mt-8 font-heading text-xl text-text">How to Calculate Loan EMI</h2>
        <p class="mt-3 text-base leading-relaxed text-muted">
          EMI is calculated from three inputs: the principal (loan amount), the interest rate, and the number of monthly payments. Convert the annual interest
          rate to a monthly rate by dividing by 12 and by 100. Then use the amortization formula to compute the fixed monthly payment. If the rate is 0%, EMI
          becomes a simple division of the principal by the number of months. Once you have the EMI, the total amount payable is EMI × months, and the total
          interest is total payable minus the original principal.
        </p>

        <h2 class="mt-8 font-heading text-xl text-text">What is EMI?</h2>
        <p class="mt-3 text-base leading-relaxed text-muted">
          EMI stands for Equated Monthly Installment. It’s the consistent monthly payment you make to repay a loan, usually including both principal and interest.
          “Equated” means the payment amount stays the same each month for a fixed-rate loan, even though the internal split between interest and principal changes.
          EMI is useful for budgeting because it lets you plan your monthly cash flow and compare different loan offers on a like-for-like basis.
        </p>

        <h2 class="mt-8 font-heading text-xl text-text">How to Get a Lower Interest Rate on a Loan</h2>
        <p class="mt-3 text-base leading-relaxed text-muted">
          Interest rates are influenced by your credit profile, income stability, existing debt, and the lender’s risk assessment. Improving your credit score,
          reducing outstanding balances, providing documentation, choosing a shorter term, or adding a co-signer can sometimes help you qualify for better rates.
          Shopping around and comparing offers from multiple lenders is also one of the simplest ways to reduce your long-term interest cost.
        </p>

        <h2 class="mt-8 font-heading text-xl text-text">Personal Loan vs Car Loan — Key Differences</h2>
        <p class="mt-3 text-base leading-relaxed text-muted">
          Personal loans are often unsecured, which can lead to higher rates because the lender has no collateral. Car loans are typically secured by the vehicle,
          and that collateral can reduce risk and sometimes lower the interest rate. Student loans may have special terms, grace periods, or government-backed
          protections depending on where you live. Business loans can vary widely in structure and may include different repayment schedules. Regardless of type,
          understanding the EMI and total interest helps you evaluate the true cost.
        </p>

        <h2 class="mt-8 font-heading text-xl text-text">Frequently Asked Questions</h2>

        <h3 class="mt-5 font-heading text-lg text-text">1. How is loan EMI calculated?</h3>
        <p class="mt-2 text-base leading-relaxed text-muted">
          EMI is calculated using the loan amount, the monthly interest rate, and the number of monthly payments. The standard EMI formula creates a fixed payment
          that amortizes the loan to zero by the end of the term.
        </p>

        <h3 class="mt-5 font-heading text-lg text-text">2. What is a good interest rate for a personal loan?</h3>
        <p class="mt-2 text-base leading-relaxed text-muted">
          A “good” rate depends on your credit profile and the market. Compare multiple offers and use the calculator to see how a rate change affects EMI and total
          interest. Lower is better, but fees and terms also matter.
        </p>

        <h3 class="mt-5 font-heading text-lg text-text">3. Can I pay off a loan early?</h3>
        <p class="mt-2 text-base leading-relaxed text-muted">
          Many loans allow early repayment, which can reduce total interest. However, some lenders charge prepayment penalties or have specific rules. Check your
          agreement before making extra payments.
        </p>

        <h3 class="mt-5 font-heading text-lg text-text">4. What happens if I miss a loan payment?</h3>
        <p class="mt-2 text-base leading-relaxed text-muted">
          Missing a payment can lead to late fees, increased interest charges, and potential damage to your credit score. If you’re struggling, contact the lender
          early—many offer temporary hardship options.
        </p>
      </article>
    </section>
  </div>

  <script is:inline>
    const form = document.getElementById('loan-form');
    const amountEl = document.getElementById('amount');
    const rateEl = document.getElementById('rate');
    const termEl = document.getElementById('term');
    const termHintEl = document.getElementById('termHint');
    const typeEl = document.getElementById('type');
    const errorEl = document.getElementById('error');

    const outEmi = document.getElementById('emi');
    const outTotalInterest = document.getElementById('totalInterest');
    const outTotalPayable = document.getElementById('totalPayable');
    const outPPct = document.getElementById('pPct');
    const outIPct = document.getElementById('iPct');
    const pBar = document.getElementById('pBar');
    const iBar = document.getElementById('iBar');
    const yearBody = document.getElementById('yearBody');
    const loanPeriodHead = document.getElementById('loanPeriodHead');

    let lastLoanMonths = null;

    function loanScheduleGranularity() {
      const el = document.querySelector('input[name="loanGranularity"]:checked');
      return el && el.value === 'month' ? 'month' : 'year';
    }

    function parseNumber(value) {
      if (!value) return null;
      const cleaned = String(value).replace(/[^0-9.\-]/g, '');
      const n = Number(cleaned);
      return Number.isFinite(n) ? n : null;
    }

    function moneyUSD(n) {
      if (n === null) return '—';
      return new Intl.NumberFormat(undefined, {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 2,
      }).format(n);
    }

    function setError(message) {
      if (!message) {
        errorEl.classList.add('hidden');
        errorEl.textContent = '';
        return;
      }
      errorEl.classList.remove('hidden');
      errorEl.textContent = message;
    }

    function renderEmpty() {
      outEmi.textContent = '—';
      outTotalInterest.textContent = '—';
      outTotalPayable.textContent = '—';
      outPPct.textContent = 'Principal: —';
      outIPct.textContent = 'Interest: —';
      pBar.style.width = '0%';
      iBar.style.width = '0%';
      yearBody.innerHTML = `
        <tr class="border-t border-border">
          <td class="px-5 py-4 text-sm text-muted" colspan="5">Calculate to see the schedule.</td>
        </tr>
      `;
      lastLoanMonths = null;
    }

    function termUnit() {
      const el = form.querySelector('input[name="termUnit"]:checked');
      return el ? el.value : 'months';
    }

    function updateTermHint() {
      termHintEl.textContent = termUnit() === 'years' ? 'Enter the term in years.' : 'Enter the term in months.';
    }

    function computeEmi(P, annualRate, months) {
      const r = annualRate / 100 / 12;
      if (months <= 0) return null;
      if (r === 0) return P / months;
      const pow = Math.pow(1 + r, months);
      return (P * r * pow) / (pow - 1);
    }

    function buildLoanMonthlyRows(P, annualRate, months, emi) {
      const r = annualRate / 100 / 12;
      let balance = P;
      const rows = [];
      for (let i = 0; i < months; i += 1) {
        const interest = balance * r;
        const principalPaid = emi - interest;
        balance -= principalPaid;
        if (balance < 0) balance = 0;
        rows.push({ monthNum: i + 1, payment: emi, interest, principalPaid, balance });
      }
      return rows;
    }

    function renderLoanScheduleTable() {
      if (!lastLoanMonths || lastLoanMonths.length === 0) {
        yearBody.innerHTML =
          '<tr class="border-t border-border"><td class="px-5 py-4 text-sm text-muted" colspan="5">Calculate to see the schedule.</td></tr>';
        return;
      }

      const gran = loanScheduleGranularity();
      loanPeriodHead.textContent = gran === 'month' ? 'Month' : 'Year';

      const n = lastLoanMonths.length;
      let rows = '';

      if (gran === 'year') {
        const totalYears = Math.ceil(n / 12);
        for (let y = 1; y <= totalYears; y += 1) {
          let interestYear = 0;
          let principalYear = 0;
          const startMonth = (y - 1) * 12;
          const endMonth = Math.min(y * 12, n);
          const numMonths = endMonth - startMonth;
          for (let m = startMonth; m < endMonth; m += 1) {
            interestYear += lastLoanMonths[m].interest;
            principalYear += lastLoanMonths[m].principalPaid;
          }
          const endIdx = endMonth - 1;
          const payTotal = numMonths * lastLoanMonths[0].payment;
          rows += `
          <tr class="border-t border-border">
            <td class="px-5 py-4 text-sm text-muted">Year ${y}</td>
            <td class="px-5 py-4 text-sm text-text">${moneyUSD(payTotal)}</td>
            <td class="px-5 py-4 text-sm text-text">${moneyUSD(interestYear)}</td>
            <td class="px-5 py-4 text-sm text-text">${moneyUSD(principalYear)}</td>
            <td class="px-5 py-4 text-sm text-text">${moneyUSD(lastLoanMonths[endIdx].balance)}</td>
          </tr>
        `;
        }
      } else {
        for (let i = 0; i < n; i += 1) {
          const row = lastLoanMonths[i];
          rows += `
          <tr class="border-t border-border">
            <td class="px-5 py-4 text-sm text-muted">Month ${row.monthNum}</td>
            <td class="px-5 py-4 text-sm text-text">${moneyUSD(row.payment)}</td>
            <td class="px-5 py-4 text-sm text-text">${moneyUSD(row.interest)}</td>
            <td class="px-5 py-4 text-sm text-text">${moneyUSD(row.principalPaid)}</td>
            <td class="px-5 py-4 text-sm text-text">${moneyUSD(row.balance)}</td>
          </tr>
        `;
        }
      }

      yearBody.innerHTML = rows;
    }

    function calculate() {
      setError('');

      const amount = parseNumber(amountEl.value);
      const annualRate = parseNumber(rateEl.value);
      const termVal = parseNumber(termEl.value);

      if (amount === null || annualRate === null || termVal === null) {
        renderEmpty();
        return;
      }

      if (amount <= 0) {
        setError('Loan amount must be greater than 0.');
        renderEmpty();
        return;
      }

      if (annualRate < 0) {
        setError('Interest rate cannot be negative.');
        renderEmpty();
        return;
      }

      let months = termVal;
      if (termUnit() === 'years') {
        months = termVal * 12;
      }

      if (!Number.isFinite(months) || months <= 0) {
        setError('Loan term must be greater than 0.');
        renderEmpty();
        return;
      }

      months = Math.round(months);

      const emi = computeEmi(amount, annualRate, months);
      if (emi === null || !Number.isFinite(emi)) {
        renderEmpty();
        return;
      }

      const totalPayable = emi * months;
      const totalInterest = totalPayable - amount;

      outEmi.textContent = moneyUSD(emi);
      outTotalInterest.textContent = moneyUSD(totalInterest);
      outTotalPayable.textContent = moneyUSD(totalPayable);

      const interestPct = totalPayable === 0 ? 0 : (totalInterest / totalPayable) * 100;
      const principalPct = 100 - interestPct;

      outPPct.textContent = 'Principal: ' + principalPct.toFixed(0) + '%';
      outIPct.textContent = 'Interest: ' + interestPct.toFixed(0) + '%';
      pBar.style.width = Math.max(0, Math.min(100, principalPct)) + '%';
      iBar.style.width = Math.max(0, Math.min(100, interestPct)) + '%';

      lastLoanMonths = buildLoanMonthlyRows(amount, annualRate, months, emi);
      renderLoanScheduleTable();

      void typeEl.value;
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      calculate();
    });

    ;[amountEl, rateEl, termEl, typeEl].forEach((el) => {
      el.addEventListener('input', calculate);
      el.addEventListener('change', calculate);
    });

    form.querySelectorAll('input[name="termUnit"]').forEach((el) => {
      el.addEventListener('change', () => {
        updateTermHint();
        calculate();
      });
    });

    form.querySelectorAll('input[name="loanGranularity"]').forEach((el) => {
      el.addEventListener('change', () => {
        if (lastLoanMonths) renderLoanScheduleTable();
      });
    });

    updateTermHint();
    renderEmpty();
  </script>
</BaseLayout>
