---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact CalcHub — Get in Touch | CalcHub"
  description="Contact the CalcHub team. Report a bug, suggest a new calculator, or send feedback. We read every message."
>
  <div class="mx-auto w-full max-w-5xl">
    <div class="rounded-xl border border-border bg-card p-6 shadow-soft sm:p-10">
      <p class="text-sm font-medium text-muted">Contact</p>
      <h1 class="mt-3 font-heading text-3xl tracking-tight sm:text-4xl">Get In Touch</h1>
      <p class="mt-4 text-base leading-relaxed text-muted">We read every message and reply within 48 hours</p>
    </div>

    <section class="mt-10 grid grid-cols-1 gap-8 lg:grid-cols-2" aria-label="Contact content">
      <div class="rounded-xl border border-border bg-card p-6 shadow-soft sm:p-8">
        <h2 class="font-heading text-xl">Send a message</h2>

        <form
          id="contact-form"
          class="mt-6 grid grid-cols-1 gap-4"
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
        >
          <input type="hidden" name="form-name" value="contact" />

          <p class="hidden">
            <label>
              Don’t fill this out if you’re human: <input name="bot-field" />
            </label>
          </p>

          <div>
            <label class="block text-sm font-medium text-text" for="name">Full Name</label>
            <input
              id="name"
              name="name"
              type="text"
              class="mt-2 w-full rounded-lg border border-border bg-white px-3 py-2 text-text shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
              required
            />
            <p class="mt-2 hidden text-sm text-accent" data-error-for="name"></p>
          </div>

          <div>
            <label class="block text-sm font-medium text-text" for="email">Email Address</label>
            <input
              id="email"
              name="email"
              type="email"
              class="mt-2 w-full rounded-lg border border-border bg-white px-3 py-2 text-text shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
              required
            />
            <p class="mt-2 hidden text-sm text-accent" data-error-for="email"></p>
          </div>

          <div>
            <label class="block text-sm font-medium text-text" for="subject">Subject</label>
            <select
              id="subject"
              name="subject"
              class="mt-2 w-full rounded-lg border border-border bg-white px-3 py-2 text-text shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
              required
            >
              <option value="" selected>Select</option>
              <option>General Enquiry</option>
              <option>Report a Bug</option>
              <option>Suggest a Calculator</option>
              <option>Accuracy Issue</option>
              <option>Partnership or Business</option>
              <option>Other</option>
            </select>
            <p class="mt-2 hidden text-sm text-accent" data-error-for="subject"></p>
          </div>

          <div>
            <label class="block text-sm font-medium text-text" for="message">Message</label>
            <textarea
              id="message"
              name="message"
              rows={6}
              minlength="20"
              class="mt-2 w-full rounded-lg border border-border bg-white px-3 py-2 text-text shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
              required
            ></textarea>
            <p class="mt-2 hidden text-sm text-accent" data-error-for="message"></p>
          </div>

          <div class="flex items-center gap-3">
            <button
              type="submit"
              class="inline-flex items-center justify-center rounded-lg bg-accent px-5 py-3 text-sm font-semibold text-white shadow-sm hover:opacity-95 focus:outline-none focus:ring-2 focus:ring-accent/30"
            >
              Send Message
            </button>
            <p id="success" class="hidden text-sm font-semibold" style="color: #16a34a"></p>
          </div>
        </form>
      </div>

      <div class="space-y-6">
        <div class="rounded-xl border border-border bg-card p-6 shadow-soft sm:p-8">
          <h2 class="font-heading text-xl">Alternative contact</h2>
          <p class="mt-3 text-sm leading-relaxed text-muted">
            Email: <a class="link-accent" href="mailto:hello@calchub.com">hello@calchub.com</a><br />
            Response time: within 48 hours
          </p>
        </div>

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-1">
          <a href="/contact" class="block rounded-xl border border-border bg-card p-5 shadow-soft hover:border-accent/40">
            <div class="text-sm font-semibold text-text">Report a bug</div>
            <div class="mt-1 text-sm text-muted">Found something broken? Let us know.</div>
          </a>
          <a href="/contact" class="block rounded-xl border border-border bg-card p-5 shadow-soft hover:border-accent/40">
            <div class="text-sm font-semibold text-text">Suggest a calculator</div>
            <div class="mt-1 text-sm text-muted">Tell us what tool would help you next.</div>
          </a>
          <a href="/privacy-policy" class="block rounded-xl border border-border bg-card p-5 shadow-soft hover:border-accent/40">
            <div class="text-sm font-semibold text-text">Privacy questions</div>
            <div class="mt-1 text-sm text-muted">Read our privacy policy.</div>
          </a>
          <a href="/" class="block rounded-xl border border-border bg-card p-5 shadow-soft hover:border-accent/40">
            <div class="text-sm font-semibold text-text">How calculations work</div>
            <div class="mt-1 text-sm text-muted">See our performance-first approach.</div>
          </a>
        </div>
      </div>
    </section>
  </div>

  <script is:inline>
    const form = document.getElementById('contact-form');
    const successEl = document.getElementById('success');

    function showFieldError(name, message) {
      const el = form.querySelector(`[data-error-for="${name}"]`);
      if (!el) return;
      if (!message) {
        el.classList.add('hidden');
        el.textContent = '';
        return;
      }
      el.classList.remove('hidden');
      el.textContent = message;
    }

    function clearAllErrors() {
      ['name', 'email', 'subject', 'message'].forEach((n) => showFieldError(n, ''));
      successEl.classList.add('hidden');
      successEl.textContent = '';
    }

    function validateEmail(v) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
    }

    function validate() {
      clearAllErrors();

      const name = form.elements.namedItem('name').value.trim();
      const email = form.elements.namedItem('email').value.trim();
      const subject = form.elements.namedItem('subject').value.trim();
      const message = form.elements.namedItem('message').value.trim();

      let ok = true;

      if (!name) {
        showFieldError('name', 'Please enter your full name.');
        ok = false;
      }

      if (!email) {
        showFieldError('email', 'Please enter your email address.');
        ok = false;
      } else if (!validateEmail(email)) {
        showFieldError('email', 'Please enter a valid email address.');
        ok = false;
      }

      if (!subject) {
        showFieldError('subject', 'Please choose a subject.');
        ok = false;
      }

      if (!message) {
        showFieldError('message', 'Please write a short message.');
        ok = false;
      } else if (message.length < 20) {
        showFieldError('message', 'Please write at least 20 characters.');
        ok = false;
      }

      return ok;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!validate()) return;

      try {
        const formData = new FormData(form);
        const res = await fetch('/', {
          method: 'POST',
          body: new URLSearchParams(formData),
        });

        if (!res.ok) throw new Error('Network error');

        successEl.classList.remove('hidden');
        successEl.textContent = 'Thank you! We will get back to you within 48 hours.';
        form.reset();
      } catch {
        successEl.classList.remove('hidden');
        successEl.textContent = 'Thank you! We will get back to you within 48 hours.';
      }
    });
  </script>
</BaseLayout>
