---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Compound Interest Calculator — Watch Your Money Grow | CalcHub"
  description="Free compound interest calculator. See how your savings and investments grow over time with the power of compounding."
>
  <div class="mx-auto w-full max-w-4xl">
    <nav class="text-sm text-muted" aria-label="Breadcrumb">
      <a class="hover:text-text" href="/">Home</a>
      <span class="px-2" aria-hidden="true">›</span>
      <span class="text-text">Compound Interest Calculator</span>
    </nav>

    <div class="mt-6">
      <p class="text-sm font-medium text-muted">Calculator</p>
      <h1 class="mt-3 font-heading text-3xl tracking-tight sm:text-4xl">Compound Interest Calculator</h1>
      <p class="mt-4 text-base leading-relaxed text-muted">
        See how your money grows over time with compound interest and optional monthly contributions.
      </p>
    </div>

    <section class="mt-8 rounded-xl border border-border bg-card p-6 shadow-soft sm:p-8" aria-label="Compound interest calculator">
      <form id="ci-form" class="grid grid-cols-1 gap-4 sm:grid-cols-2" autocomplete="off">
        <div>
          <label class="block text-sm font-medium text-text" for="principal">Initial investment / principal ($)</label>
          <input
            id="principal"
            name="principal"
            inputmode="decimal"
            placeholder="e.g. 5000"
            class="mt-2 w-full rounded-lg border border-border bg-white px-3 py-2 text-text shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
            required
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-text" for="monthly">Monthly contribution ($) (optional)</label>
          <input
            id="monthly"
            name="monthly"
            inputmode="decimal"
            placeholder="e.g. 200"
            class="mt-2 w-full rounded-lg border border-border bg-white px-3 py-2 text-text shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-text" for="rate">Annual interest rate (%)</label>
          <input
            id="rate"
            name="rate"
            inputmode="decimal"
            placeholder="e.g. 7"
            class="mt-2 w-full rounded-lg border border-border bg-white px-3 py-2 text-text shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
            required
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-text" for="years">Investment period (years)</label>
          <input
            id="years"
            name="years"
            inputmode="numeric"
            placeholder="e.g. 20"
            class="mt-2 w-full rounded-lg border border-border bg-white px-3 py-2 text-text shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
            required
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-text" for="freq">Compound frequency</label>
          <select
            id="freq"
            name="freq"
            class="mt-2 w-full rounded-lg border border-border bg-white px-3 py-2 text-text shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
          >
            <option value="1">Annually</option>
            <option value="2">Semi-annually</option>
            <option value="4">Quarterly</option>
            <option value="12" selected>Monthly</option>
            <option value="365">Daily</option>
          </select>
        </div>

        <div class="sm:col-span-2">
          <button
            type="submit"
            class="inline-flex w-full items-center justify-center rounded-lg bg-accent px-4 py-2 text-sm font-semibold text-white shadow-sm hover:opacity-95 focus:outline-none focus:ring-2 focus:ring-accent/30 sm:w-auto"
          >
            Calculate Growth
          </button>
          <p id="error" class="mt-3 hidden text-sm font-medium text-accent"></p>
        </div>
      </form>

      <div class="mt-8 rounded-xl border border-border bg-bg p-5" aria-label="Final balance">
        <div class="text-xs font-semibold uppercase tracking-wide text-muted">Final balance</div>
        <div id="final" class="mt-2 font-heading text-3xl text-text sm:text-4xl">—</div>
        <div id="finalNote" class="mt-2 text-sm text-muted">Estimated balance at the end of the period.</div>
      </div>

      <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-label="Compound interest totals">
        <div class="rounded-xl border border-border bg-card p-5">
          <div class="text-xs font-medium uppercase tracking-wide text-muted">Total contributed</div>
          <div id="contrib" class="mt-2 font-heading text-2xl text-text">—</div>
        </div>
        <div class="rounded-xl border border-border bg-card p-5">
          <div class="text-xs font-medium uppercase tracking-wide text-muted">Total interest earned</div>
          <div id="interest" class="mt-2 font-heading text-2xl text-text">—</div>
        </div>
        <div class="rounded-xl border border-border bg-card p-5">
          <div class="text-xs font-medium uppercase tracking-wide text-muted">Interest % of final</div>
          <div id="interestPct" class="mt-2 font-heading text-2xl text-text">—</div>
        </div>
        <div class="rounded-xl border border-border bg-card p-5">
          <div class="text-xs font-medium uppercase tracking-wide text-muted">Years</div>
          <div id="yearsOut" class="mt-2 font-heading text-2xl text-text">—</div>
        </div>
      </div>

      <div class="mt-6 overflow-hidden rounded-xl border border-border" aria-label="Year-by-year growth">
        <div class="bg-card px-5 py-4">
          <h2 class="font-heading text-lg text-text">Year-by-year growth</h2>
          <p class="mt-1 text-sm text-muted">A simple annual summary of contributions and interest.</p>
        </div>
        <div class="overflow-x-auto bg-white">
          <table class="min-w-full border-collapse">
            <thead>
              <tr class="border-t border-border bg-bg">
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Year</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Opening Balance</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Interest</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Contributions</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Balance</th>
              </tr>
            </thead>
            <tbody id="tableBody">
              <tr class="border-t border-border">
                <td class="px-5 py-4 text-sm text-muted">—</td>
                <td class="px-5 py-4 text-sm text-text">—</td>
                <td class="px-5 py-4 text-sm text-text">—</td>
                <td class="px-5 py-4 text-sm text-text">—</td>
                <td class="px-5 py-4 text-sm text-text">—</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="mt-12" aria-label="Compound interest calculator guide">
      <article class="prose max-w-none">
        <h1 class="font-heading text-2xl text-text">Compound Interest Calculator</h1>
        <p class="mt-4 text-base leading-relaxed text-muted">
          Compound interest is often described as “interest on interest.” Instead of earning interest only on your original principal, compounding means your
          investment can earn interest on the interest that has already been added to the balance. Over long periods, this effect can be powerful. The earlier you
          start investing, and the more consistently you contribute, the more time compounding has to work.
        </p>
        <p class="mt-4 text-base leading-relaxed text-muted">
          This free compound interest calculator lets you model an initial investment, optional monthly contributions, and a chosen interest rate. You can also
          select how often interest compounds—annually, quarterly, monthly, or even daily. While higher compounding frequency can increase growth slightly, the
          biggest drivers are usually the interest rate, time horizon, and consistent contributions.
        </p>

        <h2 class="mt-8 font-heading text-xl text-text">What is Compound Interest?</h2>
        <p class="mt-3 text-base leading-relaxed text-muted">
          Compound interest is the process of adding earned interest back into the principal so that future interest is calculated on a larger balance. If you leave
          your returns invested, your balance grows faster than with simple interest. Compounding applies to savings accounts, fixed deposits, bonds, and many investment
          portfolios, though real investment returns may fluctuate.
        </p>

        <h2 class="mt-8 font-heading text-xl text-text">The Power of Compounding — Real Life Examples</h2>
        <p class="mt-3 text-base leading-relaxed text-muted">
          Imagine investing a small amount each month. In the early years, growth can feel slow because the balance is still small. But as the balance builds, the same
          rate of return can produce much larger dollar gains. That’s why long-term investors often focus on staying consistent. Even modest contributions can add up
          significantly over 10, 20, or 30 years.
        </p>

        <h2 class="mt-8 font-heading text-xl text-text">Compound Interest vs Simple Interest</h2>
        <p class="mt-3 text-base leading-relaxed text-muted">
          Simple interest is calculated only on the original principal. Compounded returns are calculated on the principal plus previously earned interest. Over short
          periods, the difference might be small, but over longer periods compounding can lead to a noticeably larger final balance.
        </p>

        <h2 class="mt-8 font-heading text-xl text-text">How to Maximize Your Compound Interest Growth</h2>
        <p class="mt-3 text-base leading-relaxed text-muted">
          To maximize growth, focus on factors you can control: start early, contribute regularly, keep fees low, and maintain a long-term perspective. Increasing your
          contribution even slightly, or extending the investment period by a few years, can have a large impact. If returns fluctuate, consistency and diversification
          often matter more than trying to time the market.
        </p>

        <h2 class="mt-8 font-heading text-xl text-text">Frequently Asked Questions</h2>

        <h3 class="mt-5 font-heading text-lg text-text">1. What is compound interest in simple terms?</h3>
        <p class="mt-2 text-base leading-relaxed text-muted">
          It’s when your money earns interest, and then that interest also earns interest. Over time, growth accelerates because the balance keeps getting larger.
        </p>

        <h3 class="mt-5 font-heading text-lg text-text">2. How often should interest compound for best results?</h3>
        <p class="mt-2 text-base leading-relaxed text-muted">
          More frequent compounding can help slightly, but the difference is usually smaller than the impact of the interest rate and time. Monthly vs daily compounding
          often changes results by a modest amount.
        </p>

        <h3 class="mt-5 font-heading text-lg text-text">3. What is the Rule of 72?</h3>
        <p class="mt-2 text-base leading-relaxed text-muted">
          The Rule of 72 is a quick way to estimate how long it takes to double your money: divide 72 by your annual interest rate. For example, at 8% it’s roughly
          9 years.
        </p>

        <h3 class="mt-5 font-heading text-lg text-text">4. Is compound interest good or bad for borrowers?</h3>
        <p class="mt-2 text-base leading-relaxed text-muted">
          For savers, compounding is generally good because it increases growth. For borrowers, compounding can increase the total cost of debt if interest accrues on
          interest or fees. Paying down high-interest debt early can reduce compounding costs.
        </p>
      </article>
    </section>
  </div>

  <script is:inline>
    const form = document.getElementById('ci-form');
    const principalEl = document.getElementById('principal');
    const monthlyEl = document.getElementById('monthly');
    const rateEl = document.getElementById('rate');
    const yearsEl = document.getElementById('years');
    const freqEl = document.getElementById('freq');
    const errorEl = document.getElementById('error');

    const outFinal = document.getElementById('final');
    const outContrib = document.getElementById('contrib');
    const outInterest = document.getElementById('interest');
    const outInterestPct = document.getElementById('interestPct');
    const outYears = document.getElementById('yearsOut');
    const tableBody = document.getElementById('tableBody');

    function parseNumber(value) {
      if (!value) return null;
      const cleaned = String(value).replace(/[^0-9.\-]/g, '');
      const n = Number(cleaned);
      return Number.isFinite(n) ? n : null;
    }

    function moneyUSD(n) {
      if (n === null) return '—';
      return new Intl.NumberFormat(undefined, {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 2,
      }).format(n);
    }

    function setError(message) {
      if (!message) {
        errorEl.classList.add('hidden');
        errorEl.textContent = '';
        return;
      }
      errorEl.classList.remove('hidden');
      errorEl.textContent = message;
    }

    function renderEmpty() {
      outFinal.textContent = '—';
      outContrib.textContent = '—';
      outInterest.textContent = '—';
      outInterestPct.textContent = '—';
      outYears.textContent = '—';
      tableBody.innerHTML = `
        <tr class="border-t border-border">
          <td class="px-5 py-4 text-sm text-muted">—</td>
          <td class="px-5 py-4 text-sm text-text">—</td>
          <td class="px-5 py-4 text-sm text-text">—</td>
          <td class="px-5 py-4 text-sm text-text">—</td>
          <td class="px-5 py-4 text-sm text-text">—</td>
        </tr>
      `;
    }

    function periodsPerYear() {
      const n = Number(freqEl.value);
      return Number.isFinite(n) && n > 0 ? n : 12;
    }

    function calculate() {
      setError('');

      const principal = parseNumber(principalEl.value);
      const monthly = parseNumber(monthlyEl.value) ?? 0;
      const annualRate = parseNumber(rateEl.value);
      const years = parseNumber(yearsEl.value);

      if (principal === null || annualRate === null || years === null) {
        renderEmpty();
        return;
      }

      if (principal < 0 || monthly < 0) {
        setError('Amounts cannot be negative.');
        renderEmpty();
        return;
      }

      if (years <= 0) {
        setError('Investment period must be greater than 0.');
        renderEmpty();
        return;
      }

      if (annualRate < 0) {
        setError('Interest rate cannot be negative.');
        renderEmpty();
        return;
      }

      const f = periodsPerYear();
      const r = annualRate / 100;
      const totalPeriods = Math.round(years * f);

      if (totalPeriods <= 0) {
        setError('Investment period is too short for the chosen frequency.');
        renderEmpty();
        return;
      }

      const monthlyContribution = monthly;
      let balance = principal;
      let totalContrib = principal;

      let rows = '';

      for (let year = 1; year <= Math.round(years); year += 1) {
        const opening = balance;
        let interestYear = 0;
        let contribYear = 0;

        const startP = (year - 1) * f;
        const endP = Math.min(year * f, totalPeriods);

        for (let p = startP; p < endP; p += 1) {
          const periodRate = r / f;
          const interest = balance * periodRate;
          balance += interest;
          interestYear += interest;

          const monthsInPeriod = 12 / f;
          const contrib = monthlyContribution * monthsInPeriod;
          balance += contrib;
          contribYear += contrib;
          totalContrib += contrib;
        }

        const yearEnd = balance;

        rows += `
          <tr class="border-t border-border">
            <td class="px-5 py-4 text-sm text-muted">${year}</td>
            <td class="px-5 py-4 text-sm text-text">${moneyUSD(opening)}</td>
            <td class="px-5 py-4 text-sm text-text">${moneyUSD(interestYear)}</td>
            <td class="px-5 py-4 text-sm text-text">${moneyUSD(contribYear)}</td>
            <td class="px-5 py-4 text-sm text-text">${moneyUSD(yearEnd)}</td>
          </tr>
        `;
      }

      const final = balance;
      const totalInterest = final - totalContrib;
      const pct = final === 0 ? 0 : (totalInterest / final) * 100;

      outFinal.textContent = moneyUSD(final);
      outContrib.textContent = moneyUSD(totalContrib);
      outInterest.textContent = moneyUSD(totalInterest);
      outInterestPct.textContent = pct.toFixed(1) + '%';
      outYears.textContent = String(Math.round(years));

      tableBody.innerHTML = rows;
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      calculate();
    });

    ;[principalEl, monthlyEl, rateEl, yearsEl, freqEl].forEach((el) => {
      el.addEventListener('input', calculate);
      el.addEventListener('change', calculate);
    });

    renderEmpty();
  </script>
</BaseLayout>
